{
  "expo": {
    "name": "Tamalife",
    "slug": "Tamalife",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#0B0D17"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "expo-web-browser",
      "@clerk/expo",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Tamalife to choose receipt screenshots for private parsing.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "scheme": "tamalife",
    "backgroundColor": "#0B0D17",
    "splash": {
      "backgroundColor": "#0B0D17"
    }
  }
}
