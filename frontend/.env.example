# EXPO_PUBLIC_* vars are embedded in the app bundle — only put public values here.

# Clerk publishable key (safe to expose; it's the frontend key).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# API URL:
# - Android emulator: http://10.0.2.2:8000
# - iOS simulator: http://localhost:8000
# - Physical phone via Expo Go or a development build: use your computer's LAN IP,
#   e.g. http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Development-only: exposes an explicit "Try demo" action. Ignored in production builds.
EXPO_PUBLIC_ENABLE_DEMO_MODE=false

# FCM uses the native Firebase files instead of public environment variables.
# Add your Firebase project's google-services.json and GoogleService-Info.plist
# locally; both are gitignored. Create an EAS development/preview/production build
# to test push notifications, since Expo Go cannot load the native FCM module.
