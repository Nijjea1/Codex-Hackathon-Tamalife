# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real secrets.

# "development" | "staging" | "production"
ENVIRONMENT=development

# API version prefix — all v1 routes are mounted under this.
API_V1_PREFIX=/v1

# Clerk backend Secret Key (starts with sk_test_ or sk_live_).
# Found in the Clerk dashboard under "API keys". This is the ONLY Clerk
# value the backend needs. Never expose it in client code.
CLERK_SECRET_KEY=sk_test_replace_me

# Optional in development (leave blank). In production, set to the allowed
# "azp" (authorized party) values from your Clerk-authenticated clients,
# comma-separated. Example: https://app.tamalife.com,tamalife://
CLERK_AUTHORIZED_PARTIES=

# Comma-separated list of browser origins allowed to call the API (CORS).
# Native mobile apps do not use CORS; this is for Expo web + local tools.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:8090
