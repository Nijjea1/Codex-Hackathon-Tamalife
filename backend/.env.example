TAMALIFE_ENVIRONMENT=local
TAMALIFE_DEBUG=false
TAMALIFE_DATABASE_URL=sqlite+aiosqlite:///./.data/tamalife.db
# Supabase PostgreSQL example:
# TAMALIFE_DATABASE_URL=postgresql+asyncpg://app_user:password@host:5432/postgres?ssl=require
# TAMALIFE_MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:password@host:5432/postgres?ssl=require
TAMALIFE_AUTO_CREATE_SCHEMA=true
TAMALIFE_CORS_ORIGINS=http://localhost:8081,http://localhost:19006
TAMALIFE_TRUSTED_HOSTS=localhost,127.0.0.1
TAMALIFE_DATABASE_STATEMENT_TIMEOUT_MS=15000

# Clerk Backend API secret; never expose it through EXPO_PUBLIC_* variables.
TAMALIFE_CLERK_AUTH_ENABLED=true
TAMALIFE_CLERK_SECRET_KEY=sk_test_replace_me
# Optional comma-separated azp allowlist, recommended in production.
TAMALIFE_CLERK_AUTHORIZED_PARTIES=
# Optional PEM public key for networkless session-token verification.
TAMALIFE_CLERK_JWT_KEY=
TAMALIFE_CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
TAMALIFE_CLERK_DELETED_USER_POLICY=anonymize

# Used only when Clerk authentication is explicitly disabled.
TAMALIFE_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
TAMALIFE_DEFAULT_USER_EMAIL=demo@tamalife.local

TAMALIFE_EXTRACTION_PROVIDER=heuristic
TAMALIFE_OPENAI_API_KEY=
TAMALIFE_OPENAI_MODEL=gpt-5.6
TAMALIFE_OPENAI_REASONING_EFFORT=none
TAMALIFE_EXTRACTION_PROMPT_VERSION=receipt-v1

# Monthly OpenAI-assisted discovery only proposes official pricing sources.
# Keep disabled until the scheduler, review workflow, and production key are ready.
TAMALIFE_DISCOVERY_ENABLED=false
TAMALIFE_DISCOVERY_MODEL=gpt-5.6-luna
TAMALIFE_DISCOVERY_PROMPT_VERSION=source-discovery-v1
TAMALIFE_DISCOVERY_INTERVAL_DAYS=30
TAMALIFE_DISCOVERY_MAX_PROVIDERS_PER_RUN=30
TAMALIFE_DISCOVERY_MAX_SEARCHES_PER_PROVIDER=4
TAMALIFE_DISCOVERY_MAX_CANDIDATES_PER_PROVIDER=12
TAMALIFE_DISCOVERY_MIN_AUTO_ACTIVATE_CONFIDENCE=0.92
TAMALIFE_DISCOVERY_MONTHLY_COST_LIMIT_MICROS=25000000
TAMALIFE_DISCOVERY_COUNTRY=CA
TAMALIFE_DISCOVERY_CURRENCY=CAD

# Deterministic source monitoring. Fetches are restricted and validated by the
# backend; clients never supply storage paths or arbitrary fetch destinations.
TAMALIFE_SCRAPER_MONITORING_ENABLED=false
TAMALIFE_SCRAPER_USER_AGENT=TamalifePriceMonitor/1.0 (+https://tamalife.app)
TAMALIFE_SCRAPER_CONNECT_TIMEOUT_SECONDS=5
TAMALIFE_SCRAPER_READ_TIMEOUT_SECONDS=15
TAMALIFE_SCRAPER_TOTAL_TIMEOUT_SECONDS=25
TAMALIFE_SCRAPER_MAX_RESPONSE_BYTES=2097152
TAMALIFE_SCRAPER_MAX_REDIRECTS=3
TAMALIFE_SCRAPER_SOURCE_BATCH_SIZE=25
TAMALIFE_SCRAPER_SOURCE_LEASE_SECONDS=300
TAMALIFE_SCRAPER_MISSING_PLAN_THRESHOLD=2
TAMALIFE_SCRAPER_MONITOR_INTERVAL_SECONDS=3600
TAMALIFE_PRICING_EVIDENCE_STORAGE_BUCKET=pricing-evidence

TAMALIFE_STORAGE_BACKEND=local
TAMALIFE_LOCAL_STORAGE_ROOT=.data/storage
TAMALIFE_SUPABASE_URL=
TAMALIFE_SUPABASE_SERVICE_KEY=
TAMALIFE_SUPABASE_STORAGE_BUCKET=receipts
TAMALIFE_MAX_UPLOAD_BYTES=10485760
TAMALIFE_MAX_REQUEST_BODY_BYTES=12582912
TAMALIFE_ABANDONED_RECEIPT_RETENTION_DAYS=7

TAMALIFE_REDIS_URL=redis://localhost:6379/0
TAMALIFE_CACHE_ENABLED=false
TAMALIFE_CELERY_BROKER_URL=redis://localhost:6379/0
TAMALIFE_CELERY_RESULT_BACKEND=redis://localhost:6379/1
TAMALIFE_CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=60
TAMALIFE_CELERY_TASK_TIME_LIMIT_SECONDS=90
TAMALIFE_CELERY_RESULT_EXPIRES_SECONDS=3600

# The log provider is development-only. Production delivery uses an authenticated
# webhook and sends Idempotency-Key plus X-Request-ID headers.
TAMALIFE_REMINDER_DELIVERY_ENABLED=false
TAMALIFE_REMINDER_DELIVERY_PROVIDER=log
TAMALIFE_REMINDER_DELIVERY_WEBHOOK_URL=
TAMALIFE_REMINDER_DELIVERY_WEBHOOK_TOKEN=
TAMALIFE_REMINDER_MAX_ATTEMPTS=5
TAMALIFE_REMINDER_RETRY_BASE_SECONDS=30
TAMALIFE_REMINDER_RETRY_MAX_SECONDS=3600
TAMALIFE_REMINDER_PROCESSING_TIMEOUT_SECONDS=300
TAMALIFE_REMINDER_SCAN_INTERVAL_SECONDS=3600
TAMALIFE_SENTRY_DSN=
TAMALIFE_LOG_LEVEL=INFO
